# ─────────────────────────────────────────────────────
# Viral Copy Generator — Backend environment variables
# Copy to .env and fill in all values before starting.
# ─────────────────────────────────────────────────────

# Supabase
DATABASE_URL=postgres://postgres:<password>@<project-ref>.supabase.co:5432/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Encryption (AES-256-GCM) — must be at least 32 characters
ENCRYPTION_KEY=

# Google OAuth (YouTube)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Meta (Instagram + Facebook)
META_APP_ID=
META_APP_SECRET=

# App base URL (used for OAuth redirect URIs)
APP_URL=http://localhost:5173

# Phase 6: VPS public HTTPS base URL for Meta video fetch (STORE-02)
# Nginx serves /uploads/ at this URL. Must be public HTTPS.
# Example: https://vps.yourdomain.com
VPS_PUBLIC_URL=

# Optional: local uploads directory (default: /var/uploads)
# UPLOADS_PATH=/var/uploads

# Optional: TikTok API approval gate (AUTOUP-04)
# TIKTOK_APPROVED=false

# Server port (default: 3001)
# PORT=3001

# Phase 9: Content Research Engine
# Optional — YouTube trending data is skipped if this is absent (other sources still work)
# YOUTUBE_API_KEY=AIza...

# ===== Phase 11 VERIFY-05: Provider Health Check (OPTIONAL) =====
# These keys are used ONLY by the weekly provider-health-check pg-boss job
# to ping each (provider, model) combination with a minimal call. Missing keys
# produce status='not_configured' rows in admin_provider_health — the job does
# NOT fail when keys are absent.
#
# IMPORTANT: NEVER prefix with NEXT_PUBLIC_ (these are server-side only).
# Costs admin ~$0.08/year per provider (1-token call x 8 models x 52 weeks).
HEALTHCHECK_OPENAI_KEY=
HEALTHCHECK_ANTHROPIC_KEY=
HEALTHCHECK_GOOGLE_KEY=
HEALTHCHECK_DEEPSEEK_KEY=
