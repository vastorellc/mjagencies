# ============================================================
# Viral Copy Generator — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- Supabase ---
# From: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxx.supabase.co
# Frontend only (safe in browser). Old projects: anon JWT. New projects (May 2025+): sb_publishable_xxx
SUPABASE_ANON_KEY=sb_publishable_xxx
# Backend only — NEVER put this in VITE_ env vars or frontend code
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# --- Database ---
# MUST be the DIRECT connection string (non-pooled, port 5432)
# From: Supabase Dashboard → Connect → Direct
# NOT the transaction pooler (port 6543) — pg-boss requires direct connection
DATABASE_URL=postgresql://postgres:[password]@db.xxx.supabase.co:5432/postgres

# --- Frontend (Vite) ---
# These VITE_ vars are bundled into the frontend — only safe/public values here
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# --- VPS Storage ---
# Directory for uploaded video files on the VPS
UPLOADS_PATH=/var/uploads
# Public base URL served by Nginx (required for Meta video fetch)
VPS_PUBLIC_URL=https://your-vps-domain.com

# --- Server ---
PORT=3001

# --- App ---
# Base URL for OAuth redirects (Phase 2)
APP_URL=http://localhost:5173
