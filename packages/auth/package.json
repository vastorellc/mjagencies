{
  "name": "@mjagency/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./middleware": {
      "types": "./src/middleware.ts",
      "default": "./src/middleware.ts"
    },
    "./eslint": {
      "default": "./eslint/index.js"
    }
  },
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:eslint": "node eslint/require-session-first.test.js"
  },
  "dependencies": {
    "jose": "6.2.2",
    "ioredis": "5.10.1",
    "@mjagency/db": "workspace:*",
    "@mjagency/config": "workspace:*",
    "drizzle-orm": "0.45.2",
    "server-only": "0.0.1",
    "otpauth": "9.5.1",
    "qrcode": "1.5.4",
    "bcrypt": "6.0.0"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "@types/bcrypt": "5.0.2",
    "@types/qrcode": "1.5.5",
    "@mjagency/testing": "workspace:*",
    "typescript": "6.0.3",
    "vitest": "2.1.8"
  },
  "peerDependencies": {
    "next": ">=15.2.3"
  }
}
