{
  "name": "@mjagency/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./lint": {
      "types": "./src/lint/index.ts",
      "default": "./src/lint/index.ts"
    },
    "./migrate": {
      "types": "./src/migrate/index.ts",
      "default": "./src/migrate/index.ts"
    },
    "./vault": {
      "types": "./src/vault/index.ts",
      "default": "./src/vault/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate": "tsx ../../scripts/migrate-runner.ts --all",
    "db:migrate:dry": "tsx ../../scripts/migrate-runner.ts --dry-run --all",
    "db:migrate:canary": "tsx ../../scripts/migrate-runner.ts --canary"
  },
  "dependencies": {
    "@mjagency/config": "workspace:*",
    "drizzle-orm": "0.45.2",
    "postgres": "3.4.9"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "devDependencies": {
    "@mjagency/testing": "workspace:*",
    "@types/node": "22.9.0",
    "drizzle-kit": "0.31.10",
    "eslint": "9.13.0",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
