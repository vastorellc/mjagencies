{
  "name": "@mjagency/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles/theme.css": "./styles/theme.css",
    "./tokens/*.css": "./tokens/*.css",
    "./theme/types": {
      "types": "./src/theme/types.ts",
      "default": "./src/theme/types.ts"
    }
  },
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "server-only": "0.0.1"
  },
  "peerDependencies": {
    "tailwindcss": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
