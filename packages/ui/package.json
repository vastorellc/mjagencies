{
  "name": "@mjagency/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles/theme.css": "./styles/theme.css",
    "./tokens/*.css": "./tokens/*.css",
    "./dashboard": {
      "types": "./src/dashboard/index.ts",
      "default": "./src/dashboard/index.ts"
    },
    "./dashboard/dashboard.css": "./src/dashboard/dashboard.css",
    "./theme/types": {
      "types": "./src/theme/types.ts",
      "default": "./src/theme/types.ts"
    },
    "./theme/validate-theme": {
      "types": "./src/theme/validate-theme.ts",
      "default": "./src/theme/validate-theme.ts"
    }
  },
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook"
  },
  "dependencies": {
    "@mjagency/analytics": "workspace:*",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "lucide-react": "0.525.0",
    "server-only": "0.0.1",
    "web-vitals": "^4.2.4"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "tailwindcss": "^4.2.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "3.2.0",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-themes": "9.1.20",
    "@storybook/nextjs-vite": "9.1.20",
    "@storybook/test-runner": "0.24.3",
    "@testing-library/react": "^16.0.0",
    "@types/jest-image-snapshot": "6.4.0",
    "@types/node": "22.9.0",
    "@types/react": "^18 || ^19",
    "concurrently": "9.x",
    "http-server": "14.x",
    "jest-image-snapshot": "6.4.0",
    "jsdom": "^25.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "storybook": "9.1.20",
    "typescript": "5.6.3",
    "vitest": "2.1.8",
    "wait-on": "8.x"
  }
}
