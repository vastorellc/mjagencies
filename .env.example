# MJAgency — Environment Variables Example
# Copy this file to .env and populate values.
# Production/staging values are managed via Doppler (Plan 01-06).
# The .env file is gitignored; this .env.example is committed.
#
# IMPORTANT: "replace-via-doppler" is a real instruction, not a placeholder.
# Run `doppler setup` and `doppler run -- pnpm start` — values are injected automatically.

# ── Postgres superuser (used by docker-compose.yml to start the container)
POSTGRES_SUPERUSER_PASSWORD=replace-via-doppler

# ── Per-agency DB passwords
# These are used by scripts/gen-postgres-init.sh to create Postgres roles
# and by scripts/gen-pgbouncer-config.sh to generate SCRAM-SHA-256 userlist files.
# Format: <UPPER_SLUG>_DB_PASSWORD
BRAND_DB_PASSWORD=replace-via-doppler
ECOMMERCE_DB_PASSWORD=replace-via-doppler
GROWTH_DB_PASSWORD=replace-via-doppler
WEBDEV_DB_PASSWORD=replace-via-doppler
AI_DB_PASSWORD=replace-via-doppler
BRANDING_DB_PASSWORD=replace-via-doppler
STRATEGY_DB_PASSWORD=replace-via-doppler
FINANCE_DB_PASSWORD=replace-via-doppler
ENGINEERING_DB_PASSWORD=replace-via-doppler
PRODUCT_DB_PASSWORD=replace-via-doppler
VIDEO_DB_PASSWORD=replace-via-doppler
GRAPHIC_DB_PASSWORD=replace-via-doppler

# ── Redis
REDIS_PASSWORD=replace-via-doppler

# ── Cloudflare R2 (media uploads via @mjagency/media; backup target is bucket=mjagency-backups)
# Also used by pgBackRest for backup uploads (Plan 02-05) and by scripts/pgbackrest-verify-r2.ts.
R2_ACCOUNT_ID=replace-via-doppler
R2_ACCESS_KEY=replace-via-doppler
R2_SECRET_KEY=replace-via-doppler

# ── pgBackRest backup encryption (Plan 02-05, RESEARCH §4.2, T-02-012 mitigation)
# AES-256-CBC cipher passphrase for repo1-cipher-pass in pgbackrest.conf.
# Managed in Doppler shared project. Rotation procedure: see docs/runbooks/backup-restore.md.
PGBACKREST_CIPHER_PASS=replace-via-doppler

# ── Stripe CLI dev mode (TEST KEY ONLY — D-03 pitfall 3.10)
# Use ONLY sk_test_* keys here. Production/live keys are PROHIBITED in this file.
# The Stripe CLI container in docker-compose.yml forwards webhooks to
# host.docker.internal:3000/api/stripe/webhook in test mode only.
STRIPE_TEST_API_KEY=sk_test_replace-via-doppler

# ── Permissions vault encryption (REQ-018, RESEARCH §6.2)
# AES-256-GCM key material for application-layer vault encryption.
# Derived via scryptSync with salt 'mjagency-vault-kdf-salt-v1'.
# See docs/runbooks/vault-audit.md for key rotation procedure (SEC-10).
VAULT_ENCRYPTION_KEY=__SET_VIA_DOPPLER__

# ── BullMQ payload encryption (REQ-306, REQ-425, SEC-N10)
# AES-256-GCM key material for encrypting sensitive BullMQ job payloads before Redis storage.
# Derived via scryptSync with salt 'mjagency-queue-kdf-salt-v1' (separate from vault key).
BULLMQ_ENCRYPTION_KEY=__SET_VIA_DOPPLER__

# ── Auth — Doppler-managed (Plan 03-01, REQ-020, REQ-021, REQ-022)
# Distinct 64-byte hex secrets — never share access + refresh secrets.
# Generate: openssl rand -hex 64
JWT_ACCESS_SECRET=__SET_VIA_DOPPLER__   # 64-byte hex, alg=HS256, aud=mjagency-api, TTL=15min
JWT_REFRESH_SECRET=__SET_VIA_DOPPLER__  # 64-byte hex, alg=HS256, aud=mjagency-refresh, TTL=7d
REDIS_URL=redis://localhost:6379

# MFA — TOTP issuer label shown in authenticator apps
MFA_ISSUER_NAME=MJAgency

# ── SSO (Plan 03-03, REQ-026, T-03-010, T-03-011, T-03-012)
# SSO_STATE_SECRET: 64-byte hex HMAC key for signing + verifying CSRF state tokens.
#   Generate: openssl rand -hex 64
SSO_STATE_SECRET=__SET_VIA_DOPPLER__         # 64-byte hex — openssl rand -hex 64
# SSO_INTERNAL_TOKEN: shared secret between agency apps and accounts.brand.com /api/sso/exchange.
#   Restricted to internal cluster IPs via Cloudflare Access WAF rule in production.
SSO_INTERNAL_TOKEN=__SET_VIA_DOPPLER__       # shared secret between agency apps and accounts.brand.com /api/sso/exchange
# ACCOUNTS_HOST: hostname for accounts.brand.com SSO — overridable per environment.
ACCOUNTS_HOST=accounts.brand.com             # SSO host — overridable per environment

# ── Dev-only login fallback (Plan 03-03; replace with users.password_hash in later plan)
# Production login returns 501 until users.password_hash column ships (Phase 5).
# These values are ONLY used when NODE_ENV !== 'production'.
LOGIN_DEV_USER_EMAIL=admin@example.com
LOGIN_DEV_USER_PASSWORD=changeme
LOGIN_DEV_USER_ID=__SET_VIA_DOPPLER__

# ── Database app connection (Plan 03-03 login/refresh routes)
DB_APP_PASSWORD=__SET_VIA_DOPPLER__

# ──────────────────────────────────────────────────────────────────────────
# The block below was added by the silent-integration-gap audit (2026-04-29).
# Every variable is referenced in production code paths that would fail
# silently if ops doesn't set it. Anything labelled __SET_VIA_DOPPLER__
# must come from secrets management; everything else has an inline default.
# ──────────────────────────────────────────────────────────────────────────

# ── Per-agency runtime context (set by middleware/runtime, not in .env directly)
# AGENCY / AGENCY_ID / AGENCY_SLUG are read by code that assumes the host
# subdomain has already been resolved. Set in deployment env per agency app.
AGENCY=main                                    # short id used by OTel + workers
AGENCY_ID=main                                 # full agency id; same as AGENCY in single-app deploys
AGENCY_SLUG=main                               # slug used for Redis keys + queue prefixes
AGENCY_DB_PASSWORD=replace-via-doppler         # this app's per-agency Postgres role password

# ── Postgres connection (used by Drizzle + Payload)
DATABASE_URL=postgresql://app:replace-via-doppler@localhost:5432/mjagency_main

# ── Redis (BullMQ + session store + idempotency cache)
# REDIS_URL is set above; REDIS_HOST/PORT are read by createEncryptedQueue/Worker.
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Payload CMS (service-to-service calls from workers + server actions)
PAYLOAD_URL=http://localhost:3000              # base URL for Payload REST + admin
PAYLOAD_SERVER_URL=http://localhost:3000       # canonical url echoed in admin links
PAYLOAD_API_URL=http://localhost:3000/api      # convenience alias used in some packages
PAYLOAD_API_KEY=replace-via-doppler            # service token for cross-service calls
PAYLOAD_SECRET=__SET_VIA_DOPPLER__             # session signing secret; openssl rand -hex 32

# ── Public site URL (used by Next.js metadataBase, Cal.com return URLs, etc.)
PUBLIC_BASE_URL=http://localhost:3000

# ── Cloudflare (Images + R2 storage)
CLOUDFLARE_IMAGES_ACCOUNT_ID=replace-via-doppler   # Cloudflare Images account hash
R2_ENDPOINT=https://replace-via-doppler.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-via-doppler           # alias for R2_ACCESS_KEY (some packages use either)
R2_SECRET_ACCESS_KEY=replace-via-doppler       # alias for R2_SECRET_KEY
R2_MEDIA_BUCKET=mjagency-media                 # @mjagency/media uploads
R2_ESIGN_BUCKET=mjagency-esign-vault           # signed PDFs (REQ-419 chargeback evidence)
R2_RECEIPTS_BUCKET=mjagency-erasure-receipts   # CCPA erasure receipts (Plan 11-05)

# ── Stripe (live keys; STRIPE_TEST_API_KEY above is for the docker-compose CLI)
# Webhook secrets are produced by `stripe listen --print-secret` for dev
# and by the Stripe dashboard for prod. There are TWO webhook endpoints:
#   /api/stripe/webhook         → general events (the bridging worker we wired)
#   /api/stripe/invoice-webhook → invoice-only events (legacy path)
STRIPE_SECRET_KEY=__SET_VIA_DOPPLER__          # sk_live_* in prod, sk_test_* in dev
STRIPE_WEBHOOK_SECRET=__SET_VIA_DOPPLER__      # whsec_*  used by webhook signature verification
STRIPE_INVOICE_WEBHOOK_SECRET=__SET_VIA_DOPPLER__   # whsec_* for invoice-specific endpoint

# ── SMTP (email delivery via @mjagency/email/sender.ts)
SMTP_HOST=localhost
SMTP_PORT=587                                  # 465 = secure SSL, 587 = STARTTLS
SMTP_USER=__SET_VIA_DOPPLER__
SMTP_PASS=__SET_VIA_DOPPLER__
SMTP_FROM="MJ Agency <noreply@mjagency.com>"   # default sender if EMAIL_FROM unset
EMAIL_FROM="MJ Agency <noreply@mjagency.com>"  # alias used in some packages

# ── Twilio (SMS via @mjagency/sms; TCPA double-opt-in enforced in worker)
TWILIO_ACCOUNT_SID=__SET_VIA_DOPPLER__
TWILIO_AUTH_TOKEN=__SET_VIA_DOPPLER__
TWILIO_FROM=+15555555555                       # E.164 sender number (verified in Twilio console)

# ── Cal.com (booking integration; webhook signs payloads w/ HMAC-SHA256)
CAL_WEBHOOK_SECRET=__SET_VIA_DOPPLER__         # shared secret with Cal.com webhook config

# ── LiteLLM (Phase 7 AI gateway; per-agency budgets in Redis-backed counter)
LITELLM_BASE_URL=http://localhost:4000         # LiteLLM proxy URL (canonical)
LITELLM_API_URL=http://localhost:4000          # alias used by some Phase 7 paths
LITELLM_API_KEY=__SET_VIA_DOPPLER__            # master key for gateway authentication
LITELLM_ADMIN_TOKEN=__SET_VIA_DOPPLER__        # admin-tier token for budget mutations

# Per-agency LiteLLM budgets and keys follow the pattern:
#   LITELLM_BUDGET_<AGENCY>=monthly_dollar_cap        (e.g. LITELLM_BUDGET_ECOMMERCE=500)
#   LITELLM_API_KEY_<AGENCY>=<per-agency key>         (used by cost-cap counter)
# Set one pair per deployed agency. Examples:
LITELLM_BUDGET_ECOMMERCE=500
LITELLM_BUDGET_GROWTH=500
LITELLM_API_KEY_ECOMMERCE=__SET_VIA_DOPPLER__

# ── HMAC secrets for outgoing webhooks
PROPOSAL_HMAC_SECRET=__SET_VIA_DOPPLER__       # signs proposal-link previews; openssl rand -hex 32
BRAND_PORTAL_SECRET=__SET_VIA_DOPPLER__        # signs DAM brand-portal share links
SEED_JWT_TOKEN=__SET_VIA_DOPPLER__             # admin token used by scripts/seed-all-agencies.mjs

# ── Platform-level config (used by orchestrators)
# Comma-separated list of agency IDs the platform serves. Used by jobs that
# fan out across all agencies (e.g. cost-reset cron, algo-watcher).
PLATFORM_AGENCY_TARGETS=ai,branding,ecommerce,engineering,finance,graphic,growth,main,product,strategy,video,webdev

# ── NEXT_PUBLIC_* (browser-exposed; DO NOT put secrets here)
# Per CLAUDE.md Rule 7: never store secrets in NEXT_PUBLIC_* — these are
# inlined into the JS bundle and visible to every visitor.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_AGENCY_ID=main
NEXT_PUBLIC_AGENCY_SLUG=main
NEXT_PUBLIC_AGENCY_NAME="MJ Agency"
NEXT_PUBLIC_AGENCY_DOMAIN=mjagency.com
NEXT_PUBLIC_CONTACT_EMAIL=hello@mjagency.com
NEXT_PUBLIC_CAL_LINK=mjagency/intro             # Cal.com username/event-type slug
NEXT_PUBLIC_CF_ACCOUNT_ID=replace-via-doppler   # Cloudflare account id for client-side R2 ops
NEXT_PUBLIC_GA4_MEASUREMENT_ID=                 # G-XXXXXXXXXX (leave blank to disable injection)
NEXT_PUBLIC_GA4_ID=                             # legacy alias used by WebVitalsReporter
NEXT_PUBLIC_CLARITY_PROJECT_ID=                 # leave blank to disable Clarity injection
NEXT_PUBLIC_META_PIXEL_ID=                      # leave blank to disable Meta Pixel injection

# Per-agency NEXT_PUBLIC_GA4_MEASUREMENT_ID overrides follow the pattern:
#   NEXT_PUBLIC_GA4_MEASUREMENT_ID_<AGENCY_UPPER>=G-XXXXXXXXXX
NEXT_PUBLIC_GA4_MEASUREMENT_ID_WEB_ECOMMERCE=
# Same pattern for all 12 agencies if per-agency GA4 properties are used.

# ── Server-side analytics service-account material
# Per-agency GA4 service accounts (for the Data API used by dashboards + erasure).
# Pattern: GA4_API_SECRET_<AGENCY_UPPER>, GA4_PROPERTY_ID_<AGENCY_UPPER>,
#          GOOGLE_APPLICATION_CREDENTIALS_PATH_<AGENCY_UPPER>
# Document one per agency you deploy; example for ecommerce + healthcare:
GA4_API_SECRET_WEB_ECOMMERCE=__SET_VIA_DOPPLER__
GA4_PROPERTY_ID_WEB_ECOMMERCE=                  # numeric property id from GA4 admin
GA4_API_SECRET_WEB_HEALTHCARE=__SET_VIA_DOPPLER__
GOOGLE_APPLICATION_CREDENTIALS_PATH_WEB_ECOMMERCE=/secrets/ga4-ecommerce.json

# ── Per-agency Meta CAPI access tokens
# Pattern: META_ACCESS_TOKEN_<AGENCY_UPPER>=EAA...
META_ACCESS_TOKEN_WEB_ECOMMERCE=__SET_VIA_DOPPLER__

# ── CCPA legal-hold overrides (per-agency, all OPTIONAL)
# The erasure worker (registerErasureWorkers in instrumentation.node.ts) loads
# these at runtime. When ALL three are unset for an agency, the worker uses
# ESIGN-Act-safe defaults: esign records retained 7 years, tax records NOT
# retained, HIPAA NOT in effect.
#
# Pattern (per agency): LEGAL_HOLD_<AGENCY_UPPER>_<KEY>
#   _ESIGN_YEARS  — integer; 0 explicitly allows esign deletion (rare)
#   _TAX_YEARS    — integer; >0 retains tax records
#   _HIPAA        — literal "true" opts into HIPAA hold (medical_record class)
#
# Examples:
#   LEGAL_HOLD_FINANCE_TAX_YEARS=7      # finance agency: 7-year IRS retention
#   LEGAL_HOLD_HEALTHCARE_HIPAA=true    # healthcare agency: HIPAA opt-in
#   LEGAL_HOLD_LEGAL_ESIGN_YEARS=10     # legal agency: 10-year contract retention
# (No defaults set here; uncomment per-deployment as needed.)
